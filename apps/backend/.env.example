# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/meal_discovery?schema=public"

# API Keys
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Cache
CACHE_TTL=3600
CACHE_MAX=100

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

{
  "name": "meal-discovery-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w @meal-platform/backend",
    "dev:frontend": "npm run dev -w @meal-platform/frontend",
    "build:backend": "npm run build -w @meal-platform/backend",
    "build:frontend": "npm run build -w @meal-platform/frontend",
    "test": "npm run test --workspaces",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}
